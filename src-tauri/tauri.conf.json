{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dominate",
  "version": "0.4.0-alpha.1",
  "identifier": "com.dominate.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm.CMD dev",
    "beforeBuildCommand": "pnpm.CMD build"
  },
  "app": {
    "windows": [
      {
        "title": "Dominate",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "devtools": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "publisher": "Dominate",
    "category": "Utility",
    "shortDescription": "个人自动化助手",
    "longDescription": "Dominate - 基于 Tauri + Rust 的 Windows 桌面自动化管理工具"
  }
}
