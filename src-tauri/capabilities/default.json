{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Dominate 默认权限：允许前端调用所有已注册的 Tauri 命令与所需插件能力",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:path:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:image:default",

    "shell:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-read-dir",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-keys",
    "store:allow-entries",
    "store:allow-length",
    "store:allow-load",
    "store:allow-save",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
